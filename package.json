{
  "name": "duel-engine",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/server",
    "packages/client",
    "packages/shared"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:client": "npm run dev --workspace=packages/client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build --workspace=packages/client"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
